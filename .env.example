# ---- App ----
APP_NAME=SupportOps AI
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ---- Auth ----
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ---- Database (SQLAlchemy) ----
DATABASE_URL=sqlite:///./data/supportops.db

# ---- Vector database (ChromaDB) ----
CHROMA_COLLECTION=enterprise_knowledge

# ---- LLM (any OpenAI-compatible provider) ----
# OpenAI:
#   LLM_API_KEY=sk-...
#   LLM_MODEL=gpt-4o-mini
# xAI / Grok:
#   LLM_API_KEY=xai-...
#   LLM_BASE_URL=https://api.x.ai/v1
#   LLM_MODEL=grok-3-mini
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini

# ---- Embeddings ----
# local  = fastembed on CPU. No key, no network, nothing leaves the machine.
# openai = text-embedding-3-small (then set OPENAI_API_KEY below).
# xAI has no embeddings endpoint, so Grok users want "local".
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
OPENAI_API_KEY=

# ---- RAG ----
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=5

# ---- Storage ----
UPLOAD_DIR=./data/uploads
CHROMA_DIR=./data/chroma
