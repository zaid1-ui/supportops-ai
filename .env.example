# ---- App ----
APP_NAME=SupportOps AI
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ---- Auth ----
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ---- Database (SQLAlchemy) ----
DATABASE_URL=sqlite:///./data/supportops.db

# ---- Vector database (ChromaDB) ----
CHROMA_COLLECTION=enterprise_knowledge

# ---- LLM (any OpenAI-compatible provider) ----
# LLM_MODEL must carry a provider prefix — litellm uses it to route.
# OpenAI:      LLM_API_KEY=sk-...    LLM_MODEL=openai/gpt-4o-mini
LLM_MAX_RETRIES=5
# xAI / Grok:  LLM_API_KEY=xai-...   LLM_MODEL=xai/grok-3-mini
# Gemini:      LLM_API_KEY=...       LLM_MODEL=gemini/gemini-2.0-flash
# Groq:        LLM_API_KEY=gsk-...   LLM_MODEL=groq/llama-3.3-70b-versatile
# BASE_URL is optional and only needed for a non-default endpoint.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=openai/gpt-4o-mini
LLM_MAX_RETRIES=5

# ---- Embeddings ----
# local  = fastembed on CPU. No key, no network, nothing leaves the machine.
# openai = text-embedding-3-small (then set OPENAI_API_KEY below).
# xAI has no embeddings endpoint, so Grok users want "local".
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
OPENAI_API_KEY=

# ---- RAG ----
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=5

# ---- Storage ----
UPLOAD_DIR=./data/uploads
CHROMA_DIR=./data/chroma
